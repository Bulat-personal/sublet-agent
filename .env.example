# ─── Telegram (PRIMARY notification channel) ──────────────────────────────────
# 1. Open Telegram, search @BotFather, send /newbot, follow prompts
# 2. Copy the token it gives you here
TELEGRAM_BOT_TOKEN=

# 3. Global fallback chat_id (DM your bot, then run `python -m notifier --get-chat-id`)
#    Used for any region whose specific chat_id below isn't set.
TELEGRAM_CHAT_ID=

# 4. PER-REGION CHANNELS (optional but recommended — keeps each feed quiet).
#    For each region: create a Telegram channel, add your bot as admin,
#    post any message in the channel, then run:
#      python -m notifier --get-chat-id
#    It'll print every chat_id the bot can see. Paste each one below.
TELEGRAM_CHAT_ID_MANHATTAN=
TELEGRAM_CHAT_ID_NORTH_BK=
TELEGRAM_CHAT_ID_SOUTH_BK=
TELEGRAM_CHAT_ID_QUEENS=
TELEGRAM_CHAT_ID_NJ=

# ─── Reddit ───────────────────────────────────────────────────────────────────
# No setup needed — we use public RSS feeds (no API key, no app creation).

# ─── Email fallback (Resend — optional) ───────────────────────────────────────
# Free tier: 3,000 emails/month. Sign up at resend.com.
# Used as fallback if Telegram is down.
RESEND_API_KEY=

# ─── Facebook (Phase 4, OPT-IN ONLY, local-only) ──────────────────────────────
# Set to "true" to enable. Requires Playwright + burner FB account.
# DO NOT enable in GitHub Actions — bans happen fast there.
ENABLE_FACEBOOK=false
FB_COOKIES_PATH=./fb_cookies.json
